# Local dev: aponta para o postgres do docker-compose.
# Produção: cole a connection string do Neon (Settings > Connection Details).
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/fin_control

# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=troque-este-valor-por-um-segredo-aleatorio

JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# Origem do frontend, para CORS. Em produção: https://seu-app.vercel.app
CORS_ORIGINS=http://localhost:5173

# Segredo compartilhado com o Cloud Scheduler para chamar /internal/cron
CRON_SECRET=troque-este-valor-tambem
